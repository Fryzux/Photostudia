# Photostudia Environment Variables

# Django Settings
SECRET_KEY=django-insecure-dev-key-change-in-production-long-secure-string-12345
DEBUG=1

# PostgreSQL Settings
POSTGRES_USER=photostudia_user
POSTGRES_PASSWORD=photostudia_secure_pass_123
POSTGRES_DB=photostudia_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Django Superuser (auto-created on first startup)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@photostudia.ru
DJANGO_SUPERUSER_PASSWORD=Admin1234!
