{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Vite dev)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "frontend",
      "port": 5173
    },
    {
      "name": "Backend (Daphne via Docker)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "backend"],
      "port": 8000
    },
    {
      "name": "Celery Worker (Docker)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "celery"],
      "port": null
    },
    {
      "name": "Celery Beat (Docker)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "celery-beat"],
      "port": null
    },
    {
      "name": "Redis (Docker)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "redis"],
      "port": 6379
    },
    {
      "name": "PostgreSQL (Docker)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "db"],
      "port": 5432
    }
  ]
}
