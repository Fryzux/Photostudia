# Photostudia environment variables example

SECRET_KEY=your_secure_random_string_here
DEBUG=1

# For Docker/PostgreSQL use:
# DATABASE_ENGINE=postgres
# For local development without Docker:
# DATABASE_ENGINE=sqlite

POSTGRES_USER=photostudia
POSTGRES_PASSWORD=photostudia123
POSTGRES_DB=photostudia_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Email Settings (for Celery)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password

# Django Superuser (auto-created on first startup)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=your_strong_password_here

# Celery Broker
CELERY_BROKER_URL=redis://redis:6379/0

# WebSocket Channel Layer (Redis — обязательно для нескольких воркеров)
CHANNEL_LAYER_BACKEND=channels_redis.core.RedisChannelLayer
CHANNEL_REDIS_URL=redis://redis:6379/0

# CORS и хосты (для продакшена — раскомментировать и заполнить)
# CORS_ALLOWED_ORIGINS=https://yourdomain.com
# ALLOWED_HOSTS=yourdomain.com,api.yourdomain.com
