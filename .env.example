# Photostudia environment variables example

SECRET_KEY=your_secure_random_string_here
DEBUG=1

# For Docker/PostgreSQL use:
# DATABASE_ENGINE=postgres
# For local development without Docker:
# DATABASE_ENGINE=sqlite

POSTGRES_USER=photostudia
POSTGRES_PASSWORD=photostudia123
POSTGRES_DB=photostudia_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

CELERY_BROKER_URL=redis://redis:6379/0

# Optional: switch to Redis-backed WebSocket channels in multi-process setups
# CHANNEL_LAYER_BACKEND=channels_redis.core.RedisChannelLayer
# CHANNEL_REDIS_URL=redis://redis:6379/0

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=your_email@gmail.com
